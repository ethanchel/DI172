# ─── LLM Backend ───────────────────────────────────────────────────────────────
# Choose: "groq" or "ollama"
LLM_BACKEND=gemini

# ─── Groq (hosted) ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=gemini_key
GEMINI_MODEL=gemini-2.0-flash



# ─── MCP Servers ───────────────────────────────────────────────────────────────
BRAVE_API_KEY=your_brave_search_api_key_here
OUTPUT_DIR=./outputs

# ─── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/scout.log
